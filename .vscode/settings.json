{
  "latex-workshop.latex.tools": [
    {
      "name": "sync-md",
      "command": "./sync_resume.sh",
      "args": []
    },
    {
      "name": "xelatex",
      "command": "xelatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    },
    {
      "name": "pdflatex",
      "command": "pdflatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    },
    {
      "name": "bibtex",
      "command": "bibtex",
      "args": ["%DOCFILE%"]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "Sync Markdown -> XeLaTeX",
      "tools": ["sync-md", "xelatex"]
    },
    {
      "name": "XeLaTeX",
      "tools": ["xelatex"]
    },
    {
      "name": "PDFLaTeX",
      "tools": ["pdflatex"]
    },
    {
      "name": "XeLaTeX x2",
      "tools": ["xelatex", "xelatex"]
    },
    {
      "name": "PDFLaTeX -> BibTeX -> PDFLaTeX x2",
      "tools": ["pdflatex", "bibtex", "pdflatex", "pdflatex"]
    }
  ],
  "latex-workshop.latex.recipe.default": "Sync Markdown -> XeLaTeX",
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux", "*.bbl", "*.blg", "*.idx", "*.ind", "*.lof",
    "*.lot", "*.out", "*.toc", "*.acn", "*.acr", "*.alg",
    "*.glg", "*.glo", "*.gls", "*.ist", "*.fls", "*.log",
    "*.fdb_latexmk", "*.synctex.gz", "*.xdv"
  ],
  "latex-workshop.latex.autoClean.run": "onBuilt",
  "[latex]": {
    "editor.formatOnSave": false,
    "editor.wordWrap": "on"
  }
}
